#!/usr/bin/env bash
set -euo pipefail

# Cloudflare Zero Trust setup script for NixOS/darwin dotfiles
# This script helps set up Cloudflare Tunnel for private network access.

HELP="Usage: $0 [OPTIONS]
Setup Cloudflare Tunnel for Zero Trust private network access.

Options:
  --host HOST        Hostname to configure (e.g., ramen, harusame)
  --user USER        Username (default: c1)
  --cidr CIDR        Private network CIDR (default: 192.168.50.0/24)
  --help             Show this help

Steps:
  1. Install cloudflared and login
  2. Create tunnel and get tunnel ID
  3. Encrypt credentials with agenix
  4. Add cloudflared module to host configuration
  5. Deploy configuration

Example:
  $0 --host harusame --cidr 192.168.50.0/24
"

# Parse arguments
HOST=""
USER="c1"
CIDR="192.168.50.0/24"

while [[ $# -gt 0 ]]; do
  case $1 in
    --host)
      HOST="$2"
      shift 2
      ;;
    --user)
      USER="$2"
      shift 2
      ;;
    --cidr)
      CIDR="$2"
      shift 2
      ;;
    --help)
      echo "$HELP"
      exit 0
      ;;
    *)
      echo "Unknown option: $1"
      echo "$HELP"
      exit 1
      ;;
  esac
done

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

print_info() { echo -e "${BLUE}ℹ $1${NC}"; }
print_success() { echo -e "${GREEN}✓ $1${NC}"; }
print_warning() { echo -e "${YELLOW}⚠ $1${NC}"; }
print_error() { echo -e "${RED}✗ $1${NC}"; }

# Check prerequisites
print_info "Checking prerequisites..."

command -v cloudflared >/dev/null 2>&1 || {
  print_warning "cloudflared not found. Installing..."
  if command -v nix-env >/dev/null 2>&1; then
    nix-env -iA nixpkgs.cloudflared
  elif command -v apt >/dev/null 2>&1; then
    sudo apt update && sudo apt install -y cloudflared
  else
    print_error "Please install cloudflared manually: https://developers.cloudflare.com/cloudflare-one/connections/connect-apps/install-and-setup/installation/"
    exit 1
  fi
}

command -v agenix >/dev/null 2>&1 || {
  print_warning "agenix not found. It's required for secret management."
  print_info "Install via: nix-env -iA nixpkgs.agenix"
  exit 1
}

print_success "Prerequisites satisfied"

# Step 1: Login
print_info "Step 1: Cloudflare Tunnel login"
print_warning "This will open a browser for authentication..."
read -p "Press Enter to continue or Ctrl+C to cancel..."
cloudflared tunnel login || {
  print_error "Login failed. Please check your network and try again."
  exit 1
}

# Step 2: Create tunnel
print_info "Step 2: Create tunnel"
TUNNEL_NAME="home"
print_info "Creating tunnel: $TUNNEL_NAME"
TUNNEL_OUTPUT=$(cloudflared tunnel create "$TUNNEL_NAME")
echo "$TUNNEL_OUTPUT"

# Extract tunnel ID
TUNNEL_ID=$(echo "$TUNNEL_OUTPUT" | grep -oP 'Created tunnel \K[^\s]+' | head -1)
if [[ -z "$TUNNEL_ID" ]]; then
  TUNNEL_ID=$(echo "$TUNNEL_OUTPUT" | grep -oP '[a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12}' | head -1)
fi

if [[ -z "$TUNNEL_ID" ]]; then
  print_error "Could not extract tunnel ID. Please find it manually from output."
  exit 1
fi

print_success "Tunnel created with ID: $TUNNEL_ID"

# Step 3: Prepare credentials
print_info "Step 3: Prepare encrypted credentials"
CREDENTIALS_FILE="$HOME/.cloudflared/$TUNNEL_ID.json"
if [[ ! -f "$CREDENTIALS_FILE" ]]; then
  print_error "Credentials file not found: $CREDENTIALS_FILE"
  print_info "Please check if tunnel was created successfully."
  exit 1
fi

# Determine host directory
if [[ -n "$HOST" && -d "/Users/c1/Work/dotfiles/hosts/$HOST" ]]; then
  HOST_DIR="/Users/c1/Work/dotfiles/hosts/$HOST"
  SECRETS_DIR="$HOST_DIR/secrets"
elif [[ -n "$HOST" && -d "$(pwd)/hosts/$HOST" ]]; then
  HOST_DIR="$(pwd)/hosts/$HOST"
  SECRETS_DIR="$HOST_DIR/secrets"
else
  print_warning "Host directory not found or not specified. Using current directory."
  SECRETS_DIR="$(pwd)/secrets"
fi

mkdir -p "$SECRETS_DIR"
SECRET_FILE="$SECRETS_DIR/cloudflared-credentials.age"

print_info "Encrypting credentials with agenix..."
print_warning "Make sure you have the host's SSH key for encryption."
read -p "Press Enter to continue..."

agenix -e "$SECRET_FILE" -i /etc/ssh/host_ed25519 "$CREDENTIALS_FILE" || {
  print_error "Encryption failed. You may need to use a different identity file."
  print_info "Try: agenix -e $SECRET_FILE $CREDENTIALS_FILE"
  exit 1
}

print_success "Credentials encrypted: $SECRET_FILE"

# Step 4: Generate configuration snippet
print_info "Step 4: Generate Nix configuration"
CONFIG_SNIPPET=$(cat <<EOF
# Cloudflare Zero Trust Tunnel configuration
modules.services.cloudflared = {
  enable = true;
  tunnelId = "$TUNNEL_ID";
  credentialsFile = ./secrets/cloudflared-credentials.age;
  warpRouting = {
    enabled = true;
    cidrs = [ "$CIDR" ];
  };
  config = {
    # Additional YAML config (optional)
    # ingress = [ ... ];
  };
};
EOF
)

print_info "Add the following to your host configuration ($HOST_DIR/default.nix):"
echo ""
echo "$CONFIG_SNIPPET"
echo ""

# Step 5: Deployment instructions
print_info "Step 5: Deployment"
print_info "1. Add the above configuration to your host's modules section"
print_info "2. Commit and push changes"
print_info "3. Deploy with: hey sync $HOST"
print_info ""
print_info "After deployment, test with:"
print_info "  ssh ${USER}@192.168.50.227  # Linux server (atlas)"
print_info "  ssh ${USER}@192.168.50.143  # Mac (charlie)"
print_info ""
print_info "For browser SSH emergency access:"
print_info "1. Configure public hostnames in Cloudflare Zero Trust dashboard"
print_info "2. Create SSH applications for each server"
print_info "3. Enable browser rendering (SSH)"
print_info ""
print_success "Setup complete! Review the configuration before deploying."