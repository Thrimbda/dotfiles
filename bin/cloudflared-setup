#!/usr/bin/env bash
set -euo pipefail

# Cloudflare Zero Trust 设置脚本，适用于 NixOS/darwin dotfiles
# 此脚本帮助设置 Cloudflare 隧道以实现私有网络访问。

HELP="用法: $0 [选项]
设置 Cloudflare 隧道以实现 Zero Trust 私有网络访问。

选项:
  --host 主机名       要配置的主机名（例如，ramen, harusame）
  --user 用户名       用户名（默认: c1）
  --cidr CIDR        私有网络 CIDR（默认: 192.168.50.0/24）
  --help             显示此帮助信息

步骤:
  1. 安装 cloudflared 并登录
  2. 创建隧道并获取隧道 ID
  3. 使用 agenix 加密凭证
  4. 添加 cloudflared 模块到主机配置
  5. 部署配置

示例:
  $0 --host harusame --cidr 192.168.50.0/24
"

# Parse arguments
HOST=""
USER="c1"
CIDR="192.168.50.0/24"

while [[ $# -gt 0 ]]; do
  case $1 in
    --host)
      HOST="$2"
      shift 2
      ;;
    --user)
      USER="$2"
      shift 2
      ;;
    --cidr)
      CIDR="$2"
      shift 2
      ;;
    --help)
      echo "$HELP"
      exit 0
      ;;
    *)
      echo "未知选项: $1"
      echo "$HELP"
      exit 1
      ;;
  esac
done

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

print_info() { echo -e "${BLUE}ℹ $1${NC}"; }
print_success() { echo -e "${GREEN}✓ $1${NC}"; }
print_warning() { echo -e "${YELLOW}⚠ $1${NC}"; }
print_error() { echo -e "${RED}✗ $1${NC}"; }

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$SCRIPT_DIR/.." && pwd)"

# Check prerequisites
print_info "检查先决条件..."

command -v cloudflared >/dev/null 2>&1 || {
  print_warning "未找到 cloudflared，正在安装..."
  if command -v nix-env >/dev/null 2>&1; then
    nix-env -iA nixpkgs.cloudflared
  elif command -v apt >/dev/null 2>&1; then
    sudo apt update && sudo apt install -y cloudflared
  else
    print_error "请手动安装 cloudflared：https://developers.cloudflare.com/cloudflare-one/connections/connect-apps/install-and-setup/installation/"
    exit 1
  fi
}

command -v age >/dev/null 2>&1 || {
  print_warning "未找到 agenix，这是秘密管理所必需的。"
  print_info "通过以下命令安装：nix-env -iA nixpkgs.agenix"
  exit 1
}

print_success "先决条件已满足"

# Step 1: Login
print_info "步骤 1: Cloudflare 隧道登录"
if [[ -f "$HOME/.cloudflared/cert.pem" ]]; then
  print_success "检测到现有证书 ($HOME/.cloudflared/cert.pem)，跳过登录。"
else
  print_warning "这将打开浏览器进行认证..."
  read -p "按 Enter 继续或 Ctrl+C 取消..."
  cloudflared tunnel login || {
    print_error "登录失败，请检查您的网络并重试。"
    exit 1
  }
fi

# Step 2: Create tunnel
print_info "步骤 2: 创建隧道"
TUNNEL_NAME="home"
if [[ -n "$HOST" ]]; then
    TUNNEL_NAME="home-$HOST"
fi

print_info "检查隧道: $TUNNEL_NAME"

# Check if tunnel already exists
EXISTING_ID=""
if command -v rg >/dev/null 2>&1; then
    EXISTING_ID=$(cloudflared tunnel list | (rg "$TUNNEL_NAME" || true) | (rg -o '[a-f0-9]{8}-([a-f0-9]{4}-){3}[a-f0-9]{12}' || true) | head -1)
else
    EXISTING_ID=$(cloudflared tunnel list | (grep "$TUNNEL_NAME" || true) | (grep -oE '[a-f0-9]{8}-([a-f0-9]{4}-){3}[a-f0-9]{12}' || true) | head -1)
fi

if [[ -n "$EXISTING_ID" ]]; then
    print_success "隧道 $TUNNEL_NAME 已存在 (ID: $EXISTING_ID)，跳过创建。"
    TUNNEL_ID="$EXISTING_ID"
    # Ensure local credentials file exists for this ID
    if [[ ! -f "$HOME/.cloudflared/$TUNNEL_ID.json" ]]; then
        print_warning "警告: 隧道存在但在本地未找到凭证文件 $HOME/.cloudflared/$TUNNEL_ID.json"
        print_info "尝试重新创建凭证文件..."
        # Note: cloudflared doesn't have an easy "regenerate-token" command that outputs json directly without recreating
        # But 'cloudflared tunnel token $TUNNEL_ID' gives a token.
        # We might need to instruct user to re-login or delete tunnel if credentials are lost.
        print_error "请删除现有隧道 'cloudflared tunnel delete $TUNNEL_ID' 后重试，或手动恢复 JSON 凭证。"
        exit 1
    fi
else
    print_info "正在创建隧道: $TUNNEL_NAME"
    TUNNEL_OUTPUT=$(cloudflared tunnel create "$TUNNEL_NAME")
    echo "$TUNNEL_OUTPUT"

    # Extract tunnel ID
    if command -v rg >/dev/null 2>&1; then
      # Use || true to prevent pipefail if no match is found
      TUNNEL_ID=$(echo "$TUNNEL_OUTPUT" | (rg -o '[a-f0-9]{8}-([a-f0-9]{4}-){3}[a-f0-9]{12}' || true) | head -1)
    else
      # Fallback to grep -E for systems without ripgrep
      TUNNEL_ID=$(echo "$TUNNEL_OUTPUT" | (grep -oE '[a-f0-9]{8}-([a-f0-9]{4}-){3}[a-f0-9]{12}' || true) | head -1)
    fi
fi

if [[ -z "$TUNNEL_ID" ]]; then
  print_error "无法提取隧道 ID，请手动从输出中查找。"
  exit 1
fi

print_success "隧道创建成功，ID: $TUNNEL_ID"

# Step 3: Prepare credentials
print_info "步骤 3: 准备加密凭证"
CREDENTIALS_FILE="$HOME/.cloudflared/$TUNNEL_ID.json"
if [[ ! -f "$CREDENTIALS_FILE" ]]; then
  print_error "未找到凭证文件: $CREDENTIALS_FILE"
  print_info "请检查隧道是否创建成功。"
  exit 1
fi

# Determine host directory
if [[ -z "$HOST" ]]; then
  print_error "必须通过 --host 指定主机名（例如 --host charlie）。"
  exit 1
fi

if [[ -d "$REPO_ROOT/hosts/$HOST" ]]; then
  HOST_DIR="$REPO_ROOT/hosts/$HOST"
  SECRETS_DIR="$HOST_DIR/secrets"
else
  print_error "未找到主机目录: $REPO_ROOT/hosts/$HOST"
  print_info "请从仓库内运行脚本，并确认 hosts/$HOST 存在。"
  exit 1
fi

mkdir -p "$SECRETS_DIR"
SECRET_FILE="$SECRETS_DIR/cloudflared-credentials.age"

print_info "正在使用 agenix 加密凭证..."
if [[ -f "$SECRET_FILE" ]]; then
    print_warning "加密凭证文件已存在: $SECRET_FILE"
    read -p "是否覆盖? (y/N) " -n 1 -r
    echo ""
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        print_info "跳过加密步骤。"
    else
        print_warning "请确保您拥有主机的 SSH 密钥用于加密。"
        # Fix: age -e argument order changed in recent versions or our usage was wrong
        # Correct usage: age -e -i IDENTITY_FILE -o OUTPUT_FILE INPUT_FILE
        # But agenix typically uses public keys. Here we are using an identity file (private key) which implies decryption?
        # Wait, to ENCRYPT to a host, we need the host's PUBLIC key (ssh-ed25519 ...), not the private key file path with -i.
        # -i is for identities (private keys) to DECRYPT.
        # To encrypt for a recipient (public key): -r "ssh-ed25519 ..."
        
        # However, agenix CLI often abstracts this. But here we are using raw 'age'.
        # If we want to encrypt FOR the host key we found at /etc/ssh/host_ed25519.pub, we should use that.
        
        # Let's check if we have a public key available.
        if [[ -f "/etc/ssh/host_ed25519.pub" ]]; then
            PUBKEY=$(cat /etc/ssh/host_ed25519.pub)
            age -e -o "$SECRET_FILE" -r "$PUBKEY" "$CREDENTIALS_FILE"
        elif [[ -f "$HOME/.ssh/id_ed25519.pub" ]]; then
             # Fallback to user key if host key not found (typical on macOS without root)
             PUBKEY=$(cat "$HOME/.ssh/id_ed25519.pub")
             age -e -o "$SECRET_FILE" -r "$PUBKEY" "$CREDENTIALS_FILE"
        else
            print_error "未找到 SSH 公钥 (/etc/ssh/host_ed25519.pub 或 ~/.ssh/id_ed25519.pub)"
            exit 1
        fi
        print_success "凭证已重新加密: $SECRET_FILE"
    fi
else
    print_warning "请确保您拥有主机的 SSH 密钥用于加密。"
    read -p "按 Enter 继续..."
    
    if [[ -f "/etc/ssh/host_ed25519.pub" ]]; then
        PUBKEY=$(cat /etc/ssh/host_ed25519.pub)
        age -e -o "$SECRET_FILE" -r "$PUBKEY" "$CREDENTIALS_FILE"
    elif [[ -f "$HOME/.ssh/id_ed25519.pub" ]]; then
         PUBKEY=$(cat "$HOME/.ssh/id_ed25519.pub")
         age -e -o "$SECRET_FILE" -r "$PUBKEY" "$CREDENTIALS_FILE"
    else
        print_error "未找到 SSH 公钥 (/etc/ssh/host_ed25519.pub 或 ~/.ssh/id_ed25519.pub)"
        exit 1
    fi
    
    print_success "凭证已加密: $SECRET_FILE"
fi

# Step 4: Generate configuration snippet
print_info "步骤 4: 生成 Nix 配置"
CONFIG_SNIPPET=$(cat <<EOF
# Cloudflare Zero Trust 隧道配置
modules.services.cloudflared = {
  enable = true;
  tunnelId = "$TUNNEL_ID";
  credentialsFile = ./secrets/cloudflared-credentials.age;
  warpRouting.enabled = false;
  extraConfig = {
    # 额外的 YAML 配置（可选）
    # ingress = [ ... ];
  };
};
EOF
)

print_info "将以下内容添加到主机文件 $HOST_DIR/default.nix 的 config = { ... }: { ... } 配置体内："
echo ""
echo "$CONFIG_SNIPPET"
echo ""

# Step 5: Deployment instructions
print_info "步骤 5: 部署"
print_info "1. 将上述配置添加到主机文件的 config = { ... }: { ... } 配置体内"
print_info "2. 提交并推送更改"
print_info "3. 使用以下命令部署：hey sync $HOST"
print_info ""
print_info "部署后，使用以下命令测试："
print_info "  ssh ${USER}@192.168.50.227  # Linux 服务器 (atlas)"
print_info "  ssh ${USER}@192.168.50.143  # Mac (charlie)"
print_info ""
print_info "对于浏览器 SSH 紧急访问："
print_info "1. 在 Cloudflare Zero Trust 控制台中配置公开主机名"
print_info "2. 为每个服务器创建 SSH 应用"
print_info "3. 启用浏览器渲染 (SSH)"
print_info ""
print_success "设置完成！部署前请审查配置。"
